{
  "name": "motiva-layer",
  "version": "0.1.0",
  "description": "Motivation framework for AI agents via Claude Code Hooks",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "motiva": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const{mkdirSync,copyFileSync}=require('fs');const{join}=require('path');mkdirSync('dist/templates',{recursive:true});copyFileSync('src/templates/motiva-usage.md','dist/templates/motiva-usage.md');\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "yaml": "^2.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
